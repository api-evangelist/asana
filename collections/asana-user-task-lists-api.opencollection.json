          "docs": "Asana Get a user task list"
        },
        {
          "info": {
            "name": "Asana Get a user's task list",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://app.asana.com/api/1.0/users/:user_gid/user_task_list",
            "params": [
              {
                "name": "user_gid",
                "value": "",
                "type": "path"
              },
              {
                "name": "workspace",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Asana Get a user's task list"
        }
      ]
    }
  ],
  "bundled": true
}