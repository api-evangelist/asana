{
  "opencollection": "1.0.0",
  "info": {
    "name": "Asana User Task Lists API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "User Task Lists",
        "type": "folder"
      },
      "items": [
        {
          "info": {
