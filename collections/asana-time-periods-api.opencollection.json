{
  "opencollection": "1.0.0",
  "info": {
    "name": "Asana Time Periods API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Time Periods",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Asana Get a time period",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://app.asana.com/api/1.0/time_periods/:time_period_gid",
            "params": [
              {
                "name": "time_period_gid",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Asana Get a time period"
        },
        {
          "info": {
            "name": "Asana Get time periods",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://app.asana.com/api/1.0/time_periods",
            "params": [
              {
                "name": "workspace",
                "value": "",
                "type": "query"
              },
              {
                "name": "start_on",
                "value": "",
                "type": "query"
              },
              {
                "name": "end_on",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Asana Get time periods"
        }
      ]
    }
  ],
  "bundled": true
}