{
  "opencollection": "1.0.0",
  "info": {
    "name": "Asana Rule Triggers API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Rules",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Asana Trigger a rule",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://app.asana.com/api/1.0/rule_triggers/:rule_trigger_gid/run",
            "params": [
              {
                "name": "rule_trigger_gid",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Trigger a rule which uses an incoming web request trigger."
        }
      ]
    }
  ],
  "bundled": true
}