    "_postman_id": "d840fa0e-f943-411b-ad24-fca6f7ee28e2",
    "name": "Asana Events API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Asana Events API allows users to track changes to resources using event subscriptions. Events are delivered within a minute on average, designed for at-most-once delivery, and are retrievable from the event stream for 24 hours.\n\nContact Support:\n Name: Asana Support",
      "type": "text/plain"
    }
