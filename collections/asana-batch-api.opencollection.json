{
  "opencollection": "1.0.0",
  "info": {
    "name": "Asana Batch API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Batch API",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Asana Submit parallel requests",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://app.asana.com/api/1.0/batch",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Make multiple API requests in a single call. The maximum number of actions allowed in a single batch request is 10."
        }
      ]
    }
  ],
  "bundled": true
}