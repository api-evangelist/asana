              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates a goal relationship by adding a supporting resource."
        },
        {
          "info": {
            "name": "Asana Removes a supporting goal relationship",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://app.asana.com/api/1.0/goals/:goal_gid/removeSupportingRelationship",
            "params": [
              {
                "name": "goal_gid",
                "value": "",
