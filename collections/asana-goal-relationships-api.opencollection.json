{
  "opencollection": "1.0.0",
  "info": {
    "name": "Asana Goal Relationships API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
