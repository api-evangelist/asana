{
  "opencollection": "1.0.0",
  "info": {
    "name": "Asana Jobs API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Jobs",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Asana Get a job by id",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://app.asana.com/api/1.0/jobs/:job_gid",
            "params": [
              {
                "name": "job_gid",
                "value": "12345",
                "type": "path"
              }
            ]
          },
          "docs": "Returns the full record for a job."
        }
      ]
    }
  ],
  "bundled": true
}