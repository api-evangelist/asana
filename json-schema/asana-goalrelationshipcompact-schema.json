{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/GoalRelationshipCompact",
  "title": "GoalRelationshipCompact",
  "type": "object",
  "properties": {
    "gid": {
      "type": "string",
      "readOnly": true,
      "example": "12345"
    },
    "resource_type": {
      "type": "string",
      "readOnly": true,
      "example": "goal_relationship"
    },
    "resource_subtype": {
      "type": "string",
      "example": "subgoal"
    },
    "supporting_resource": {
      "type": "object",
      "properties": {
        "gid": {
          "type": "string"
        },
        "resource_type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "contribution_weight": {
      "type": "number",
      "example": 1
    }
  }
}