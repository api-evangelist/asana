{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/GoalRequest",
  "title": "GoalRequest",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "example": "Grow web traffic by 30%"
    },
    "notes": {
      "type": "string"
    },
    "html_notes": {
      "type": "string"
    },
    "due_on": {
      "type": "string",
      "format": "date",
      "nullable": true
    },
    "start_on": {
      "type": "string",
      "format": "date",
      "nullable": true
    },
    "liked": {
      "type": "boolean"
    },
    "team": {
      "type": "string"
    },
    "workspace": {
      "type": "string"
    },
    "time_period": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "followers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}