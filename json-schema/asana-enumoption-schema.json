{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/EnumOption",
  "title": "EnumOption",
  "type": "object",
  "properties": {
    "gid": {
      "type": "string",
      "readOnly": true,
      "example": "12345"
    },
    "resource_type": {
      "type": "string",
      "readOnly": true,
      "example": "enum_option"
    },
    "name": {
      "type": "string",
      "example": "Low"
    },
    "enabled": {
      "type": "boolean",
      "example": true
    },
    "color": {
      "type": "string",
      "example": "blue"
    }
  }
}