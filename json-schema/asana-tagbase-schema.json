{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/TagBase",
  "title": "TagBase",
  "allOf": [
    {
      "$ref": "#/components/schemas/TagCompact"
    },
    {
      "type": "object",
      "properties": {
        "color": {
          "type": "string",
          "description": "Color of the tag.",
          "nullable": true,
          "enum": [
            "dark-pink",
            "dark-green",
            "dark-blue",
            "dark-red",
            "dark-teal",
            "dark-brown",
            "dark-orange",
            "dark-purple",
            "dark-warm-gray",
            "light-pink",
            "light-green",
            "light-blue",
            "light-red",
            "light-teal",
            "light-brown",
            "light-orange",
            "light-purple",
            "light-warm-gray",
            null
          ],
          "example": "light-green"
        },
        "notes": {
          "description": "Free-form textual information associated with the tag (i.e. its description).",
          "type": "string",
          "example": "Mittens really likes the stuff from Humboldt."
        }
      }
    }
  ]
}