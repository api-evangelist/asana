{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/GoalCompact",
  "title": "GoalCompact",
  "type": "object",
  "properties": {
    "gid": {
      "type": "string",
      "readOnly": true,
      "example": "12345"
    },
    "resource_type": {
      "type": "string",
      "readOnly": true,
      "example": "goal"
    },
    "name": {
      "type": "string",
      "example": "Grow web traffic by 30%"
    },
    "owner": {
      "type": "object",
      "properties": {
        "gid": {
          "type": "string"
        },
        "resource_type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    }
  }
}