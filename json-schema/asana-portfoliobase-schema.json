{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/PortfolioBase",
  "title": "PortfolioBase",
  "allOf": [
    {
      "$ref": "#/components/schemas/PortfolioCompact"
    },
    {
      "type": "object",
      "properties": {
        "archived": {
          "description": "[Opt In](/docs/inputoutput-options). True if the portfolio is archived, false if not. Archived portfolios do not show in the UI by default and may be treated differently for queries.",
          "type": "boolean",
          "example": false
        },
        "color": {
          "description": "Color of the portfolio.",
          "type": "string",
          "enum": [
            "dark-pink",
            "dark-green",
            "dark-blue",
            "dark-red",
            "dark-teal",
            "dark-brown",
            "dark-orange",
            "dark-purple",
            "dark-warm-gray",
            "light-pink",
            "light-green",
            "light-blue",
            "light-red",
            "light-teal",
            "light-brown",
            "light-orange",
            "light-purple",
            "light-warm-gray"
          ],
          "example": "light-green"
        }
      }
    }
  ]
}