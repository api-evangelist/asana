  "info": {
    "_postman_id": "256ff539-e3e3-4a33-8fbb-6f0459c4e3df",
    "name": "Asana Batch API",
    "description": "The Asana Batch API enables developers to perform multiple actions by making only a single HTTP request. The maximum number of actions allowed in a single batch request is 10. Actions are dispatched in parallel.\n\nContact Support:\n Name: Asana Support",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T13:13:36.000Z",
