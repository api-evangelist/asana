      "item": [
        {
          "name": "Asana Submit parallel requests",
          "id": "6bd1bd9f-a668-4b90-a96b-a48e745a445d",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"actions\": [\n      {\n        \"relative_path\": \"<string>\",\n        \"method\": \"delete\",\n        \"data\": {},\n        \"options\": {\n          \"limit\": \"<integer>\",\n          \"offset\": \"<string>\",\n          \"fields\": [\n            \"<string>\",\n            \"<string>\"\n          ]\n        }\n      },\n      {\n        \"relative_path\": \"<string>\",\n        \"method\": \"put\",\n        \"data\": {},\n        \"options\": {\n          \"limit\": \"<integer>\",\n          \"offset\": \"<string>\",\n          \"fields\": [\n            \"<string>\",\n            \"<string>\"\n          ]\n        }\n      }\n    ]\n  }\n}",
              "options": {
                "raw": {
                  "headerFamily": "json",
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/batch",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "batch"
              ]
            },
            "description": "Make multiple API requests in a single call. The maximum number of actions allowed in a single batch request is 10."
