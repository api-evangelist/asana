  "info": {
    "_postman_id": "ccc159c5-2767-46c5-a605-0ef4245b46d5",
    "name": "Asana Events API",
    "description": "The Asana Events API allows users to track changes to resources using event subscriptions. Events are delivered within a minute on average, designed for at-most-once delivery, and are retrievable from the event stream for 24 hours.\n\nContact Support:\n Name: Asana Support",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "createdAt": "2026-06-05T13:13:40.000Z",
